{
  "name": "rpg-cheat-ui-plugin-docs",
  "version": "1.2.2",
  "description": "Documentation for RPG Maker MV/MZ Cheat UI Plugin",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc -p tsconfig.json",
    "check:mv-compat": "node tools/check-mv-compat.mjs",
    "check:repo": "pnpm run typecheck && pnpm run check:mv-compat && pnpm run docs:build",
    "format": "prettier . --write",
    "prepare": "husky install"
  },
  "keywords": [
    "rpg-maker",
    "mz",
    "mv",
    "translation-tool",
    "cheat-engine-program"
  ],
  "author": "Eduwilll",
  "license": "MIT",
  "devDependencies": {
    "@fenixengine/rmmz-ts": "^1.2.0",
    "@types/node": "^25.5.2",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "mermaid": "^11.14.0",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "vitepress": "^1.3.4",
    "vitepress-plugin-group-icons": "^1.7.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "lint-staged": {
    "**/*.{js,json,css}": "prettier --write"
  }
}
