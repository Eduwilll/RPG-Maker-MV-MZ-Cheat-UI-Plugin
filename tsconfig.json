{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "typeRoots": ["./types", "./node_modules/@types"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "cheat-engine/www/cheat/**/*.js",
    "preview/**/*.js",
    "node_modules/@fenixengine/rmmz-ts/libs/external/**/*.d.ts",
    "node_modules/@fenixengine/rmmz-ts/libs/rmmz/**/*.d.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "docs/.vitepress/cache",
    "docs/.vitepress/dist",
    "output",
    "tmp",
    ".venv"
  ]
}
